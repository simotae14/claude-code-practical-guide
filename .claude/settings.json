{
  "enabledPlugins": {
    "skill-creator@claude-plugins-official": true
  },
  "effortLevel": "medium",
  "theme": "dark-daltonized",
  "permissions": {
    "deny": ["Bash(**/.env)", "Read(**/.env)", "Write(**/.env)"]
  },
  "alwaysThinkingEnabled": false,
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" & bun run format 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
